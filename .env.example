# ══════════════════════════════════
#  MikroBot Configuration
# ══════════════════════════════════

# Telegram Bot (dari @BotFather)
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=123456789

# MikroTik Router (via WireGuard tunnel)
ROUTER_HOST=10.10.10.2
ROUTER_PORT=80
ROUTER_USER=mikrobot
ROUTER_PASS=your_strong_password


# Settings
USERNAME_LENGTH=6
TIMEZONE=Asia/Jakarta

# Anti-tether (blok HP share hotspot / wifi+hotspot)
# TTL=1 ke client + drop TTL 63/127 + bind MAC first login
ANTI_TETHER=true
HOTSPOT_INTERFACE=ether4
HOTSPOT_SUBNET=192.168.20.0/24
